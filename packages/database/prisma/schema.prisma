// Multi-tenancy: tenantId added to all scoped models in E16-02

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// prisma seed config in package.json

enum Role {
  USER
  COUNTER_SELLER
  ADMIN
  SUPER_ADMIN
}

enum PlanTier {
  FREE
  PRO
  ENTERPRISE
}

enum PlanStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum PlatformAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum PlatformAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
}

enum AnnouncementType {
  MAINTENANCE
  FEATURE
  POLICY
}

enum TenantMemberRole {
  ADMIN
  COUNTER_SELLER
}

enum BusType {
  AC
  NON_AC
}

enum SeatClass {
  STANDARD
  PREMIUM
  BUSINESS
}

enum SeatStatus {
  AVAILABLE
  HELD
  SOLD
}

enum BookingStatus {
  DRAFT
  HELD
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  ONLINE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ScheduleStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum CounterTransactionType {
  SELL
  CHANGE
  REFUND
  CANCEL
}

enum NotificationChannel {
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum SiteMediaKind {
  HERO
  FEATURED
  FOOTER_PAYMENT
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  bookings            Booking[]
  counterTransactions CounterTransaction[] @relation("SellerTransactions")
  tenantMemberships   TenantMembership[]

  @@map("users")
}

model Stop {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  name      String
  city      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  routesFrom Route[] @relation("RouteFrom")
  routesTo   Route[] @relation("RouteTo")

  @@index([tenantId])
  @@index([city])
  @@map("stops")
}

model Route {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  fromStopId String   @map("from_stop_id")
  toStopId   String   @map("to_stop_id")
  slug       String
  distanceKm Int?     @map("distance_km")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromStop       Stop            @relation("RouteFrom", fields: [fromStopId], references: [id])
  toStop         Stop            @relation("RouteTo", fields: [toStopId], references: [id])
  schedules      Schedule[]
  boardingPoints BoardingPoint[]
  featuredRoutes FeaturedRoute[]

  @@unique([tenantId, slug])
  @@unique([tenantId, fromStopId, toStopId])
  @@index([tenantId])
  @@index([slug])
  @@map("routes")
}

model Coach {
  id           String   @id @default(cuid())
  tenantId     String?  @map("tenant_id")
  coachNumber  String   @unique @map("coach_number")
  busType      BusType  @map("bus_type")
  seatLayoutId String?  @map("seat_layout_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  seatLayout SeatLayout? @relation(fields: [seatLayoutId], references: [id])
  schedules  Schedule[]

  @@index([tenantId])
  @@map("coaches")
}

model SeatLayout {
  id        String   @id @default(cuid())
  tenantId  String?  @map("tenant_id")
  name      String
  rows      Int
  cols      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templates SeatTemplate[]
  coaches   Coach[]

  @@index([tenantId])
  @@map("seat_layouts")
}

model SeatTemplate {
  id           String    @id @default(cuid())
  seatLayoutId String    @map("seat_layout_id")
  label        String
  row          Int
  col          Int
  seatClass    SeatClass @map("seat_class")

  seatLayout SeatLayout @relation(fields: [seatLayoutId], references: [id], onDelete: Cascade)

  @@unique([seatLayoutId, label])
  @@map("seat_templates")
}

model BoardingPoint {
  id        String @id @default(cuid())
  routeId   String @map("route_id")
  name      String
  sortOrder Int    @map("sort_order")

  route    Route     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([routeId])
  @@map("boarding_points")
}

model Schedule {
  id                 String         @id @default(cuid())
  tenantId           String?        @map("tenant_id")
  routeId            String         @map("route_id")
  coachId            String         @map("coach_id")
  departureAt        DateTime       @map("departure_at")
  estimatedArrivalAt DateTime       @map("estimated_arrival_at")
  status             ScheduleStatus @default(SCHEDULED)
  baseFare           Int            @map("base_fare")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  tenant         Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  route          Route           @relation(fields: [routeId], references: [id])
  coach          Coach           @relation(fields: [coachId], references: [id])
  scheduleSeats  ScheduleSeat[]
  bookings       Booking[]
  rescheduleLogs RescheduleLog[]

  @@index([tenantId])
  @@index([routeId, departureAt])
  @@index([routeId, status, departureAt])
  @@map("schedules")
}

model RescheduleLog {
  id                String   @id @default(cuid())
  scheduleId        String   @map("schedule_id")
  previousDeparture DateTime @map("previous_departure")
  newDeparture      DateTime @map("new_departure")
  reason            String?
  createdAt         DateTime @default(now()) @map("created_at")

  schedule Schedule @relation(fields: [scheduleId], references: [id])

  @@map("reschedule_logs")
}

model ScheduleSeat {
  id         String     @id @default(cuid())
  scheduleId String     @map("schedule_id")
  label      String
  seatClass  SeatClass  @map("seat_class")
  status     SeatStatus @default(AVAILABLE)
  price      Int

  schedule     Schedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  holdItems    SeatHoldItem[]
  bookingSeats BookingSeat[]

  @@unique([scheduleId, label])
  @@index([scheduleId, status])
  @@map("schedule_seats")
}

model SeatHold {
  id         String   @id @default(cuid())
  scheduleId String   @map("schedule_id")
  sessionId  String   @map("session_id")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  items   SeatHoldItem[]
  booking Booking?

  @@index([expiresAt])
  @@map("seat_holds")
}

model SeatHoldItem {
  id             String @id @default(cuid())
  holdId         String @map("hold_id")
  scheduleSeatId String @map("schedule_seat_id")

  hold         SeatHold     @relation(fields: [holdId], references: [id], onDelete: Cascade)
  scheduleSeat ScheduleSeat @relation(fields: [scheduleSeatId], references: [id])

  @@unique([holdId, scheduleSeatId])
  @@map("seat_hold_items")
}

model Booking {
  id              String        @id @default(cuid())
  tenantId        String?       @map("tenant_id")
  scheduleId      String        @map("schedule_id")
  userId          String?       @map("user_id")
  holdId          String?       @unique @map("hold_id")
  boardingPointId String        @map("boarding_point_id")
  passengerName   String        @map("passenger_name")
  passengerPhone  String        @map("passenger_phone")
  passengerEmail  String?       @map("passenger_email")
  status          BookingStatus @default(DRAFT)
  totalAmount     Int           @map("total_amount")
  soldById        String?       @map("sold_by_id")
  channel         String        @default("ONLINE")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant        Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule      Schedule             @relation(fields: [scheduleId], references: [id])
  user          User?                @relation(fields: [userId], references: [id])
  hold          SeatHold?            @relation(fields: [holdId], references: [id])
  boardingPoint BoardingPoint        @relation(fields: [boardingPointId], references: [id])
  seats         BookingSeat[]
  payment       Payment?
  ticket        Ticket?
  counterTxns   CounterTransaction[]
  notifications NotificationLog[]

  @@index([tenantId])
  @@index([passengerPhone])
  @@index([userId])
  @@index([status, createdAt])
  @@map("bookings")
}

model BookingSeat {
  id             String @id @default(cuid())
  bookingId      String @map("booking_id")
  scheduleSeatId String @map("schedule_seat_id")
  price          Int

  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  scheduleSeat ScheduleSeat @relation(fields: [scheduleSeatId], references: [id])

  @@unique([bookingId, scheduleSeatId])
  @@map("booking_seats")
}

model Payment {
  id             String        @id @default(cuid())
  bookingId      String        @unique @map("booking_id")
  amount         Int
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  idempotencyKey String?       @unique @map("idempotency_key")
  providerRef    String?       @map("provider_ref")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Ticket {
  id              String   @id @default(cuid())
  bookingId       String   @unique @map("booking_id")
  passengerNumber String   @unique @map("passenger_number")
  qrPayload       String?  @map("qr_payload")
  createdAt       DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("tickets")
}

model CounterTransaction {
  id        String                 @id @default(cuid())
  tenantId  String?                @map("tenant_id")
  type      CounterTransactionType
  sellerId  String                 @map("seller_id")
  bookingId String                 @map("booking_id")
  amount    Int
  note      String?
  createdAt DateTime               @default(now()) @map("created_at")

  tenant  Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  seller  User    @relation("SellerTransactions", fields: [sellerId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([tenantId])
  @@index([sellerId, createdAt])
  @@map("counter_transactions")
}

model NotificationLog {
  id        String              @id @default(cuid())
  tenantId  String?             @map("tenant_id")
  bookingId String              @map("booking_id")
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  recipient String
  error     String?
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  tenant  Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, channel])
  @@index([tenantId])
  @@index([status, createdAt])
  @@map("notification_logs")
}

model Tenant {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  subdomainPrefix String     @unique @map("subdomain_prefix")
  customDomain    String?    @unique @map("custom_domain")
  planTier        PlanTier   @default(FREE) @map("plan_tier")
  planStatus      PlanStatus @default(TRIAL) @map("plan_status")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  members          TenantMembership[]
  stops            Stop[]
  routes           Route[]
  coaches          Coach[]
  seatLayouts      SeatLayout[]
  schedules        Schedule[]
  bookings         Booking[]
  counterTxns      CounterTransaction[]
  notificationLogs NotificationLog[]
  siteProfiles     SiteProfile[]
  siteThemes       SiteTheme[]
  contentPages     ContentPage[]
  siteMedia        SiteMedia[]
  featuredRoutes   FeaturedRoute[]
  footerSettings   FooterSettings[]
  subscription     Subscription?
  apiLogs          PlatformApiLog[]
  supportTickets   SupportTicket[]
  platformAlerts   PlatformAlert[]
  invoices         PlatformInvoice[]

  @@index([slug])
  @@index([subdomainPrefix])
  @@map("tenants")
}

model PlatformAuditLog {
  id           String   @id @default(cuid())
  actorId      String?  @map("actor_id")
  actorName    String   @map("actor_name")
  actorType    String   @map("actor_type")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  changes      Json?
  ipAddress    String?  @map("ip_address")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([resourceType, resourceId])
  @@map("platform_audit_logs")
}

model PlatformApiLog {
  id             String   @id @default(cuid())
  tenantId       String?  @map("tenant_id")
  userId         String?  @map("user_id")
  method         String
  endpoint       String
  statusCode     Int      @map("status_code")
  responseTimeMs Int      @map("response_time_ms")
  createdAt      DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@index([endpoint])
  @@map("platform_api_logs")
}

model Subscription {
  id                String             @id @default(cuid())
  tenantId          String             @unique @map("tenant_id")
  planTier          PlanTier           @map("plan_tier")
  status            SubscriptionStatus @default(TRIAL)
  monthlyPriceMinor Int                @map("monthly_price_minor")
  billingCycleStart DateTime           @map("billing_cycle_start")
  billingCycleEnd   DateTime           @map("billing_cycle_end")
  nextBillDate      DateTime?          @map("next_bill_date")
  autoRenew         Boolean            @default(true) @map("auto_renew")
  usageMetrics      Json?              @map("usage_metrics")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices PlatformInvoice[]

  @@index([status])
  @@index([nextBillDate])
  @@map("subscriptions")
}

model SupportTicket {
  id           String         @id @default(cuid())
  tenantId     String         @map("tenant_id")
  subject      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  assignedToId String?        @map("assigned_to_id")
  createdByName String        @map("created_by_name")
  createdAt    DateTime       @default(now()) @map("created_at")
  resolvedAt   DateTime?      @map("resolved_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  @@index([tenantId])
  @@index([status, priority])
  @@map("support_tickets")
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  authorName String   @map("author_name")
  authorType String   @map("author_type")
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

model PlatformAlert {
  id             String               @id @default(cuid())
  severity       PlatformAlertSeverity
  title          String
  message        String
  status         PlatformAlertStatus  @default(OPEN)
  source         String               @default("SYSTEM")
  ruleKey        String?              @map("rule_key")
  tenantId       String?              @map("tenant_id")
  acknowledgedAt DateTime?            @map("acknowledged_at")
  resolvedAt     DateTime?            @map("resolved_at")
  createdAt      DateTime             @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([tenantId])
  @@map("platform_alerts")
}

model PlatformInvoice {
  id             String        @id @default(cuid())
  tenantId       String        @map("tenant_id")
  subscriptionId String        @map("subscription_id")
  invoiceNumber  String        @unique @map("invoice_number")
  amountMinor    Int           @map("amount_minor")
  periodStart    DateTime      @map("period_start")
  periodEnd      DateTime      @map("period_end")
  status         InvoiceStatus @default(PENDING)
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([status])
  @@map("platform_invoices")
}

model PlatformAnnouncement {
  id          String           @id @default(cuid())
  title       String
  body        String
  type        AnnouncementType
  tenantIds   Json?            @map("tenant_ids")
  sendToAll   Boolean          @default(true) @map("send_to_all")
  scheduledAt DateTime?        @map("scheduled_at")
  sentAt      DateTime?        @map("sent_at")
  createdById String?          @map("created_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([sentAt])
  @@map("platform_announcements")
}

model TenantMembership {
  id       String           @id @default(cuid())
  tenantId String           @map("tenant_id")
  userId   String           @map("user_id")
  role     TenantMemberRole

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("tenant_memberships")
}

model SiteProfile {
  id             String        @id @default(cuid())
  tenantId       String?       @map("tenant_id")
  companyName    String        @map("company_name")
  tagline        String?
  logoUrl        String?       @map("logo_url")
  faviconUrl     String?       @map("favicon_url")
  tradeLicenseNo String?       @map("trade_license_no")
  status         ContentStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("site_profiles")
}

model SiteTheme {
  id           String        @id @default(cuid())
  tenantId     String?       @map("tenant_id")
  primaryColor String        @map("primary_color")
  fontFamily   String        @default("Inter") @map("font_family")
  paletteJson  Json          @map("palette_json")
  status       ContentStatus @default(DRAFT)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("site_themes")
}

model ContentPage {
  id           String        @id @default(cuid())
  tenantId     String?       @map("tenant_id")
  slug         String
  title        String
  bodyMarkdown String        @map("body_markdown") @db.Text
  status       ContentStatus @default(DRAFT)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug, status])
  @@index([tenantId])
  @@index([tenantId, slug])
  @@map("content_pages")
}

model SiteMedia {
  id        String        @id @default(cuid())
  tenantId  String?       @map("tenant_id")
  kind      SiteMediaKind
  url       String
  alt       String        @default("")
  sortOrder Int           @map("sort_order")
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind, sortOrder, status])
  @@index([tenantId])
  @@index([tenantId, kind, status])
  @@map("site_media")
}

model FeaturedRoute {
  id        String        @id @default(cuid())
  tenantId  String?       @map("tenant_id")
  routeId   String        @map("route_id")
  sortOrder Int           @map("sort_order")
  isVisible Boolean       @default(true) @map("is_visible")
  status    ContentStatus @default(DRAFT)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  route  Route   @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, routeId, status])
  @@index([tenantId])
  @@index([tenantId, status, sortOrder])
  @@map("featured_routes")
}

model FooterSettings {
  id               String        @id @default(cuid())
  tenantId         String?       @map("tenant_id")
  contactLines     Json          @map("contact_lines")
  email            String
  paymentBannerUrl String?       @map("payment_banner_url")
  barLinks         Json          @map("bar_links")
  poweredByText    String?       @map("powered_by_text")
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("footer_settings")
}
