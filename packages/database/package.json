{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "generate": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev --name migration",
    "migrate:init": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "@prisma/client": "^6.9.0",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "bcryptjs": "^3.0.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
